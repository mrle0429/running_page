            <ns3:atemp>22.0</ns3:atemp>
            <ns3:hr>169</ns3:hr>
            <ns3:cad>90</ns3:cad>
          </ns3:TrackPointExtension>
        </extensions>
      </trkpt>
    </trkseg>
  </trk>
</gpx>
